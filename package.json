{
  "name": "urlaub-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:web": "npm --workspace packages/web run dev",
    "dev:api": "npm --workspace packages/api run dev",
    "test": "npm --workspaces --if-present run test",
    "build": "npm --workspaces --if-present run build"
  }
}
